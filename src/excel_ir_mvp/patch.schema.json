          "sheet": {"type": "string"},
          "sheet_index": {"type": "integer"},
          "table": {"type": "string"},
          "ref": {"type": "string"},
          "coord": {"type": "string"},
          "value": {},
          "formula": {"type": "string"},
          "where": {},
          "updates": {"type": "object"},
          "field_map": {"type": "object"},
          "rows": {"type": "array"},
          "values": {},
          "formulas": {"type": "object"}
